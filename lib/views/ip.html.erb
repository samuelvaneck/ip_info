<div id='content'>
  <div id='map' data-lat='<%= @latitude %>' data-lng='<%= @longitude %>'></div>
  <div id='ip-card'>
    <div id='ip-row'>
      <span id='ip'><%= @remote_ip %></span>
      <button type='button' id='copy-btn' data-ip='<%= @remote_ip %>' aria-label='Copy IP address' title='Copy IP'>
        <svg id='copy-icon-default' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
          <rect x='9' y='9' width='13' height='13' rx='2' ry='2'></rect>
          <path d='M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1'></path>
        </svg>
        <svg id='copy-icon-done' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
          <polyline points='20 6 9 17 4 12'></polyline>
        </svg>
      </button>
    </div>
    <% locality = [@location[:city], @location[:country]].compact %>
    <% if locality.any? %>
      <div id='location'><%= locality.join(' • ') %></div>
    <% end %>
    <% if @location[:isp] || (@latitude && @longitude) %>
      <dl id='meta'>
        <% if @location[:isp] %>
          <dt>ISP</dt><dd><%= @location[:isp] %></dd>
        <% end %>
        <% if @latitude && @longitude %>
          <dt>Coords</dt><dd><%= format('%.4f, %.4f', @latitude, @longitude) %></dd>
        <% end %>
      </dl>
    <% end %>
  </div>
</div>

<script src='/javascript/copy_ip.js' defer></script>
<script async src='https://maps.googleapis.com/maps/api/js?key=<%= ENV['GOOGLE_MAPS_KEY'] %>&callback=initMap'></script>
